{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "hw/map-geojson",
  "version": "1.0.0",
  "title": "Map based on GeoJSON",
  "category": "widgets",
  "icon": "download",
  "description": "Display a Map based on a GeoJSON anywhere in the content.",
  "keywords": ["geojson", "map", "route"],
  "supports": {
    "html": false
  },
  "attributes": {
    "attachmentId": {
      "type": "number",
      "default": 0
    },
    "fileUrl": {
      "type": "string",
      "default": ""
    },
    "fileName": {
      "type": "string",
      "default": ""
    },
    "buttonText": {
      "type": "string",
      "default": "GeoJSON Map"
    },
    "openInNewTab": {
      "type": "boolean",
      "default": false
    }
  },
  "textdomain": "hw-map-geojson",
  "editorScript": "hw-map-geojson-editor"
}
